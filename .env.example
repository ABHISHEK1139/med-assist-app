# Med Assist App backend configuration
MED_ASSIST_APP_HOST=127.0.0.1
MED_ASSIST_APP_PORT=8000
MED_ASSIST_APP_MODEL_PATH=models/med-assist-app-2b.task
MED_ASSIST_APP_MAX_TOKENS=1024
MED_ASSIST_APP_TEMPERATURE=0.7
MED_ASSIST_APP_TOP_K=40
MED_ASSIST_APP_USE_GPU=true
MED_ASSIST_APP_GPU_DEVICE_ID=0
MED_ASSIST_APP_MEMORY_PATH=memory
MED_ASSIST_APP_EMBEDDING_MODEL=all-MiniLM-L6-v2
MED_ASSIST_APP_MAX_CONTEXT_DOCUMENTS=5
MED_ASSIST_APP_MEMORY_RETENTION_DAYS=30

# Optional: Hugging Face token for gated models
MED_ASSIST_APP_HF_TOKEN=

# Optional: Telegram bot token (for backend/src/telegram/bot.py)
MED_ASSIST_APP_TELEGRAM_BOT_TOKEN=
